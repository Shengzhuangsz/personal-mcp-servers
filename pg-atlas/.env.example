# Lark Open Platform credentials (海外 larksuite 租户).
# 获取: https://open.larksuite.com/app → 你的 app → "Credentials and Basic Info"
# 这个 app 需要授予的权限至少包括:
#   - im:message:send_as_bot       (发消息)
#   - contact:user.base:readonly    (邮箱反查 open_id)
#   - bitable:app:readonly          (查 Bitable 记录)
#   - drive:file                    (上传图到 Lark Doc)
#   - docx:document                 (读写 Lark Doc)
PG_LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
PG_LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选: PG 知识库根目录 (kb_search tool 在这里搜)
# 不设置则 kb_search 返回空, 其他 tool 不受影响
PG_KB_ROOT=/path/to/KnowledgeBase
PG_SOP_PATH=/path/to/sop_requirement_check.md
