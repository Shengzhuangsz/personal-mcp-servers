# Lark Open Platform credentials (海外 larksuite 租户).
# 获取: https://open.larksuite.com/app → 你的 app → "Credentials and Basic Info"
# 这个 app 需要授予的权限:
#   - docx:document                 (读写 Lark Doc 块)
#   - drive:file                    (新建文档 + 上传图片)
#   - drive:drive                   (转让所有权 transfer_ownership)
#   - contact:user.base:readonly    (邮箱反查 open_id)
PG_LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
PG_LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
